  {
    "id": "f694e276-c111-4079-a715-a927adaefe08",
    "type": "heading",
    "props": {
      "backgroundColor": "default",
      "textColor": "default",
      "textAlignment": "left",
      "level": 3,
      "isToggleable": false
    },
    "content": [
      {
        "type": "text",
        "text": "한국에서의 적용 가능성",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "f3e008dc-1ef8-4fcf-a5ca-d3645b38b022",
    "type": "paragraph",
    "props": {
      "backgroundColor": "default",
      "textColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "아시아에서의 임상 경험을 살펴보면 PAD를 적극 도입하는데 사회적, 문화적 장벽이 가로막을 수 있음을 알 수 있다. PAD는 개인의 자율성과 미래 지향적 의사결정을 전제로 하지만, 많은 아시아 사회에서는 여전히 가족 중심의 의사결정 구조가 강하게 작동한다. 따라서 개인이 사전에 결정하더라도 나중에 가족이 이에 반발하는 상황이 발생할 수 있으며, 이는 PAD의 실질적 효력을 약화시키는 요인으로 작용한다. 또한, 유교권 문화에 공통적인 온정적 간섭주의 역시 중요한 장애물이다. 아시아 여러 국가에서는 환자의 최선의 이익을 의료진이 결정하는 관행이 만연하며, 이는 환자의 사전 의사를 존중하려는 시도와 충돌할 수 있다. 물론 제도적, 교육적 기반이 충분히 마련되어 있지 않다는 것도 중요한 요인이다.",
        "styles": {}
      },
      {
        "type": "citation",
        "props": {
          "citekey": "poremski2019psychiatric",
          "locator": ""
        }
      },
      {
        "type": "text",
        "text": "  ",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "9531f0c6-fc92-4094-8d5f-66472d2121ed",
    "type": "paragraph",
    "props": {
      "backgroundColor": "default",
